# ═══════════════════════════════════════════════
# 🏆 Delta Gold - Variables d'environnement
# Copiez ce fichier vers .env et remplissez les valeurs
# ═══════════════════════════════════════════════

# ── Propriétaire du bot ──
OWNER_NUMBER=224612908366
OWNER_NAME=Mcamara

# ── Préfixe des commandes ──
BOT_PREFIX=.

# ── IA Mistral (optionnel) ──
# Obtenez une clé sur https://console.mistral.ai
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest
MISTRAL_INSTRUCTIONS=Tu es Delta Gold, assistant WhatsApp intelligent et amical créé par Mcamara. Réponds de manière concise et utile en français.

# ── Liens (optionnel) ──
CHANNEL_LINK=

# ── Port du serveur ──
PORT=3000
